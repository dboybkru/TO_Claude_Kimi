# SecureTO — Server Environment Variables
# Скопируй в .env и замени все CHANGEME!

# ── Database ─────────────────────────────────────────────────────────────
POSTGRES_USER=secureto
POSTGRES_PASSWORD=CHANGEME_STRONG_PASSWORD
POSTGRES_DB=secureto

# ── Redis ──────────────────────────────────────────────────────────────
# По умолчанию подключается автоматически через docker network

# ── MinIO ──────────────────────────────────────────────────────────────
MINIO_ROOT_USER=secureto
MINIO_ROOT_PASSWORD=CHANGEME_MINIO_PASSWORD

# ── Backend JWT ────────────────────────────────────────────────────────
SECRET_KEY=CHANGEME_64_CHAR_RANDOM_STRING_HERE
ACCESS_TOKEN_EXPIRE_MINUTES=30
REFRESH_TOKEN_EXPIRE_DAYS=30

# ── First Superuser (создаётся автоматически) ──────────────────────────
FIRST_SUPERUSER_EMAIL=admin@secureto.local
FIRST_SUPERUSER_PASSWORD=CHANGEME_ADMIN_PASSWORD

# ── AI / VseGPT ────────────────────────────────────────────────────────
VSEGPT_API_KEY=CHANGEME_VSEGPT_KEY
VSEGPT_BASE_URL=https://api.vsegpt.ru/v1
VSEGPT_PARSE_CALL_MODEL=openai/gpt-4o-mini
VSEGPT_CLASSIFY_FAULT_MODEL=openai/gpt-4o-mini
VSEGPT_STT_MODEL=openai/whisper-1
VSEGPT_TTS_MODEL=openai/tts-1
VSEGPT_SUMMARIZE_MODEL=anthropic/claude-haiku-4.5
VSEGPT_GENERATE_REPORT_MODEL=anthropic/claude-sonnet-4.5

# ── Email (SMTP) ───────────────────────────────────────────────────────
SMTP_SERVER=smtp.yandex.ru
SMTP_PORT=465
SMTP_USER=noreply@yourdomain.ru
SMTP_PASSWORD=CHANGEME_SMTP_PASSWORD
EMAIL_FROM=SecureTO <noreply@yourdomain.ru>

# ── Sentry (опционально) ───────────────────────────────────────────────
SENTRY_DSN=

# ── Voice Bot (опционально) ────────────────────────────────────────────
ASTERISK_HOST=voice-bot
ASTERISK_PORT=5038
ASTERISK_USER=secureto
ASTERISK_PASSWORD=CHANGEME_AMI_PASSWORD

# ── App Config ─────────────────────────────────────────────────────────
APP_ENV=production
APP_NAME=SecureTO
APP_VERSION=1.0.0

# ── CORS ───────────────────────────────────────────────────────────────
# Указать IP сервера и любые другие разрешённые источники
CORS_ORIGINS=http://168.222.140.21,http://168.222.140.21:8080

# ── Robot API Key ────────────────────────────────────────────────────────
ROBOT_API_KEY=CHANGEME_ROBOT_KEY_32_CHARS
