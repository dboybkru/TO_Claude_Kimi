# Application
APP_ENV=development
SECRET_KEY=change-me-to-a-long-random-string-at-least-32-chars
ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=30
REFRESH_TOKEN_EXPIRE_DAYS=30

# Database
POSTGRES_USER=alarm
POSTGRES_PASSWORD=alarm_secret
POSTGRES_DB=alarm_db
POSTGRES_HOST=db
POSTGRES_PORT=5432
DATABASE_URL=postgresql+asyncpg://alarm:alarm_secret@db:5432/alarm_db

# Redis
REDIS_URL=redis://redis:6379/0

# MinIO
MINIO_ENDPOINT=minio:9000
MINIO_ROOT_USER=minioadmin
MINIO_ROOT_PASSWORD=minioadmin
MINIO_BUCKET_ATTACHMENTS=attachments
MINIO_SECURE=false

# CORS
CORS_ORIGINS=["http://localhost:3000","http://localhost:5173"]

# First superuser (auto-created on startup)
FIRST_SUPERUSER_EMAIL=admin@example.com
FIRST_SUPERUSER_PASSWORD=changeme

# ── Monitoring ────────────────────────────────────────────────────────────────
# Get DSN at https://sentry.io (free tier available)
SENTRY_DSN=

# ── Voice Bot Telephony ───────────────────────────────────────────────────────
# Номер телефона, который принимает звонки (для отображения в UI)
# Купить номер можно на: MangoOffice, Zadarma, Voximplant, UIS
VOICEBOT_PHONE_NUMBER=+7 (4012) XXX-XX-XX
# HMAC-SHA256 секрет для проверки запросов от АТС (X-Webhook-Signature: sha256=...)
VOICEBOT_WEBHOOK_SECRET=

# ── AI / VseGPT ───────────────────────────────────────────────────────────────
# Get your API key at https://vsegpt.ru
VSEGPT_API_KEY=your-vsegpt-api-key-here
VSEGPT_BASE_URL=https://api.vsegpt.ru/v1

# Model overrides (optional — defaults are set in config.py)
# AI_MODEL_PARSE_CALL=openai/gpt-4o-mini     # $0.02/$0.08 per 1K — call parsing
# AI_MODEL_CLASSIFY=openai/gpt-4o-mini        # $0.02/$0.08 per 1K — fault classification
# AI_MODEL_SUMMARIZE=anthropic/claude-haiku-4-5  # $0.14/$0.70 per 1K — journal summary
# AI_MODEL_REPORT=anthropic/claude-sonnet-4-6    # $0.40/$2.00 per 1K — full reports
